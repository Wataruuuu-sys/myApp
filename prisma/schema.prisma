generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Todo {
  id        Int      @id @default(autoincrement())
  title     String
  createdAt DateTime @default(now())
}

enum TopicStatus {
  open
  closed
  answered
}

model Topic {
  id         Int         @id @default(autoincrement())
  title      String
  status     TopicStatus @default(open)
  closed_at  DateTime?
  created_at DateTime    @default(now())
  answers    Answer[]
}

enum AnswerType {
  number
}

model Answer {
  id          Int          @id @default(autoincrement())
  fk_topic_id Int
  answer_type AnswerType
  created_at  DateTime     @default(now())
  topic       Topic        @relation(fields: [fk_topic_id], references: [id])
  numbers     AnswerNumber[]
}

model AnswerNumber {
  id           Int      @id @default(autoincrement())
  fk_answer_id Int
  answer       Float
  created_at   DateTime @default(now())
  answer_rel   Answer   @relation(fields: [fk_answer_id], references: [id])
}
