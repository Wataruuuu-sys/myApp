generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Todo {
  id        Int      @id @default(autoincrement())
  title     String
  createdAt DateTime @default(now())
}

enum TopicStatus {
  open
  closed
  answered
}

model Topic {
  id          Int          @id @default(autoincrement())
  title       String
  status      TopicStatus  @default(open)
  closed_at   DateTime?
  created_at  DateTime     @default(now())
  answers     Answer[]
  predictions Prediction[]
}

enum AnswerType {
  number
}

model Answer {
  id          Int          @id @default(autoincrement())
  fk_topic_id Int
  answer_type AnswerType
  created_at  DateTime     @default(now())
  topic       Topic        @relation(fields: [fk_topic_id], references: [id])
  numbers     AnswerNumber[]
}

model AnswerNumber {
  id           Int      @id @default(autoincrement())
  fk_answer_id Int
  answer       Float
  created_at   DateTime @default(now())
  answer_rel   Answer   @relation(fields: [fk_answer_id], references: [id])
}

enum PredictionType {
  number
}

model Prediction {
  id              Int              @id @default(autoincrement())
  fk_topic_id     Int
  prediction_type PredictionType
  fk_bet_id       Int?             @unique
  created_at      DateTime         @default(now())
  topic           Topic            @relation(fields: [fk_topic_id], references: [id])
  numbers         PredictionNumber[]
  bet             Bet?             @relation(name: "PredictionToBet", fields: [fk_bet_id], references: [id])
  betSource       Bet?             @relation(name: "BetToPrediction")
}

model Bet {
  id                Int        @id @default(autoincrement())
  fk_prediction_id  Int        @unique
  value             Float
  prediction        Prediction @relation(name: "BetToPrediction", fields: [fk_prediction_id], references: [id])
  predictionTarget  Prediction? @relation(name: "PredictionToBet")
}

model PredictionNumber {
  id                Int        @id @default(autoincrement())
  fk_prediction_id  Int
  predict           Float
  created_at        DateTime   @default(now())
  prediction        Prediction @relation(fields: [fk_prediction_id], references: [id])
}
