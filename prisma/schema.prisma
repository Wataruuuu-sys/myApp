generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Todo {
  id        Int      @id @default(autoincrement())
  title     String
  createdAt DateTime @default(now())
}

enum TopicStatus {
  open
  closed
  answered
}

model Topic {
  id         Int         @id @default(autoincrement())
  title      String
  status     TopicStatus @default(open)
  closed_at  DateTime?
  created_at DateTime    @default(now())
}
